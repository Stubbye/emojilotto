# ─── Upstash Redis FREE tier ──────────────────────────────────────────────────
# Sign up free at upstash.com (no credit card)
# Create a Redis database → copy REST URL and Token below
# Free tier: 10,000 req/day — enough for 9k users with 30s caching
UPSTASH_REDIS_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_TOKEN=YOUR_UPSTASH_TOKEN

# ─── Security ─────────────────────────────────────────────────────────────────
