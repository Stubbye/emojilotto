NEXT_PUBLIC_PROGRAM_ID=BSddc8F1yCUqNnMDSYhtBC79Huu3GZHfJPTJngQSM7Ru
NEXT_PUBLIC_EMLO_MINT=YOUR_EMLO_MINT_ADDRESS_HERE
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_USDC_ROUND_ID=1
NEXT_PUBLIC_EMLO_ROUND_ID=1
